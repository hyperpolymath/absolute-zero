#
# Intentfile — north-star contractile for absolute-zero.
# Verb: intend. Non-gating — this is a report, not a gate (see Mustfile for
# hard gates).
#   [[intents]] — "we WILL do this; track progress"
#                 status: declared -> in_progress -> done | deferred | retired
#   [[wishes]]  — "we WISH this were true; revisit later"
#                 status: declared -> in_progress -> achieved | abandoned
#                 horizon: near / mid / far
#
# Populated 2026-06-12 (governance checkpoint): replaces the
# rsr-template-repo stub. Sources: README.adoc, ROADMAP.adoc,
# descriptiles/STATE.a2ml ([route-to-mvp], [critical-next-actions], [blockers-and-issues]).
# A2ML here is TOML-flavoured.

[metadata]
repo = "absolute-zero"
contractile-verb = "intend"
last-updated = "2026-06-12"
abstract = "North star for absolute-zero: machine-checked proofs that Certified Null Operations (CNOs) do nothing, across six proof systems, en route to a publication release."

[purpose]
statement = "Formal verification of Certified Null Operations — programs provably having zero net computational effect — formalised across Coq, Lean 4, Z3, Agda, Isabelle and Mizar, with an Idris2-proved ABI and cross-language demonstration examples."

[anti-purpose]
not = [
  "A production runtime or deployed service (research repo; service-security checks are kept only for estate consistency)",
  "A general-purpose proof framework — the subject is CNOs and their thermodynamic/categorical meaning",
  "A language-advocacy showcase — banned-language files under examples/ exist to demonstrate cross-language nop semantics, not to endorse those languages",
]

[if-in-doubt]
sensitive-areas = ["proofs/", "src/abi/", ".github/workflows/", ".claude/CLAUDE.md", "LICENSE"]
guidance = "Proof semantics and licensing are maintainer-gated; ask before touching."

